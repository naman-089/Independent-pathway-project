rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isCaseworker() { return isSignedIn() && callerRole() == "caseworker"; }
    function isAdmin()      { return isSignedIn() && callerRole() == "admin"; }
    function isStaff()      { return isCaseworker() || isAdmin(); }

    // ── Users ──────────────────────────────────────────────────────────────
    // Families read/write their own doc. Staff can read all users.
    // Self-signup is locked to role="family" — staff accounts must be
    // provisioned by an admin (never via the sign-up form with a code).
    // Owners cannot escalate their own role; only admins can change roles.
    match /users/{uid} {
      // list queries (e.g. "give me all caseworkers") are allowed for any
      // signed-in user so the DM sidebar can discover caseworkers.
      allow list:   if isSignedIn();
      // Single-document reads are tighter: own profile, any staff, or reading
      // a staff profile (so families can fetch a caseworker's displayName by UID).
      allow get:    if isOwner(uid) || isStaff() || resource.data.role in ["caseworker", "admin"];
      allow create: if isOwner(uid) && request.resource.data.role == "family";
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin() && request.auth.uid != uid;
    }

    // ── Intakes ────────────────────────────────────────────────────────────
    match /intakes/{uid} {
      allow read:   if isOwner(uid) || isStaff();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isStaff();
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── Matches ────────────────────────────────────────────────────────────
    match /matches/{uid} {
      allow read:   if isOwner(uid) || isStaff();
      allow write:  if isStaff();
      allow delete: if isAdmin();
    }

    // ── Organizations ──────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Community channel ──────────────────────────────────────────────────
    // Enforce that the stored uid matches the caller and cap message size.
    // Messages are immutable once posted; only admins can delete.
    match /communityMessages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── Direct messages ────────────────────────────────────────────────────
    // Conversation ID is "<uid_a>_<uid_b>" (UIDs sorted lexicographically).
    // Only the two participants may read or write their thread.
    match /dms/{conversationId}/messages/{messageId} {
      allow read, write: if isSignedIn() && (
        conversationId.matches('^' + request.auth.uid + '_.+$') ||
        conversationId.matches('^.+_' + request.auth.uid + '$')
      );
    }
  }
}
