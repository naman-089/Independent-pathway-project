rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any signed-in user can read/write their own user doc
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Staff (caseworker/admin) can read all user docs
      allow read: if request.auth != null;
    }

    // Intakes — owner can read/write, any signed-in user can read (caseworkers need this)
    match /intakes/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Matches — any signed-in user can read, any signed-in user can write
    // (caseworkers confirm matches; for demo we keep it open)
    match /matches/{uid} {
      allow read, write: if request.auth != null;
    }

    // Organizations — any signed-in user can read, any signed-in user can write
    // (tighten to admin-only after demo if needed)
    match /organizations/{orgId} {
      allow read, write: if request.auth != null;
    }
  }
}
