rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isCaseworker() { return isSignedIn() && callerRole() == "caseworker"; }
    function isAdmin()      { return isSignedIn() && callerRole() == "admin"; }
    function isStaff()      { return isCaseworker() || isAdmin(); }

    // ── Users ──────────────────────────────────────────────────────────────
    // Families read/write their own doc.
    // Staff can read all users.
    // Admins can also delete any user doc (used by the delete user feature).
    match /users/{uid} {
      allow read:   if isOwner(uid) || isStaff();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin() && request.auth.uid != uid; // can't delete yourself
    }

    // ── Intakes ────────────────────────────────────────────────────────────
    // Families read/write their own intake.
    // Staff can read all intakes.
    // Admins can delete any intake (cleanup when deleting a user).
    match /intakes/{uid} {
      allow read:   if isOwner(uid) || isStaff();
      allow create,
            update: if isOwner(uid);
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── Matches ────────────────────────────────────────────────────────────
    // Families read their own match.
    // Caseworkers/admins read & write all matches.
    // Admins can delete matches (cleanup when deleting a user).
    match /matches/{uid} {
      allow read:   if isOwner(uid) || isStaff();
      allow write:  if isStaff();
      allow delete: if isAdmin();
    }

    // ── Organizations ──────────────────────────────────────────────────────
    // Any signed-in user can read; only admins can create/update/delete.
    match /organizations/{orgId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
