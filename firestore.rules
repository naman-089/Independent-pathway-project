rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Reads the caller's role from their user doc (cached by Firestore rules engine)
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isCaseworker() { return isSignedIn() && callerRole() == "caseworker"; }
    function isAdmin()      { return isSignedIn() && callerRole() == "admin"; }
    function isStaff()      { return isCaseworker() || isAdmin(); }

    // ── Users ──────────────────────────────────────────────────────────────
    // Families read/write their own doc; staff can read all users.
    match /users/{uid} {
      allow read:  if isOwner(uid) || isStaff();
      allow write: if isOwner(uid);
    }

    // ── Intakes ────────────────────────────────────────────────────────────
    // Families read/write their own intake; staff can read all intakes.
    match /intakes/{uid} {
      allow read:  if isOwner(uid) || isStaff();
      allow write: if isOwner(uid);
    }

    // ── Matches ────────────────────────────────────────────────────────────
    // Families read their own match; caseworkers/admins read & write all.
    match /matches/{uid} {
      allow read:  if isOwner(uid) || isStaff();
      allow write: if isStaff();
    }

    // ── Organizations ──────────────────────────────────────────────────────
    // Any signed-in user can read; only admins can create/update/delete.
    match /organizations/{orgId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
